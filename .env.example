# Database
DATABASE_URL=postgresql://gallery:gallery@localhost:5432/gallery_hub
DATABASE_SSL=false

# MinIO / S3
# MINIO_ENDPOINT is what server-side code uses (inside Docker: http://gallery-minio:9000).
# MINIO_PUBLIC_ENDPOINT is what presigned URLs use — what the browser sees.
# In dev they can be the same. In prod expose MinIO via its own Cloudflare Tunnel
# hostname and set MINIO_PUBLIC_ENDPOINT=https://minio.gallery.divass.space.
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gallery
MINIO_FORCE_PATH_STYLE=true
# CORS origin MinIO allows for browser uploads. In prod set to your PUBLIC_BASE_URL.
MINIO_API_CORS_ALLOW_ORIGIN=*

# Admin seed (used only by scripts/seed-admin.ts)
ADMIN_EMAIL=admin@divass.space
ADMIN_PASSWORD=qwertyAI

# iron-session (32+ chars)
SESSION_PASSWORD=replace-me-with-a-32-plus-character-secret

# Public base URL (used for absolute links)
PUBLIC_BASE_URL=http://localhost:3000

# Widget endpoint (/api/widget/summary) — shared bearer token with personal-hub.
# Leave unset to disable the endpoint (returns 503). Use 32+ random chars.
WIDGET_TOKEN=

# ----------------------------------------------------------------------------
# PostHog (self-hosted via docker-compose). Browser SDK and server SDK both
# read POSTHOG_KEY + POSTHOG_HOST. Leave unset to disable analytics entirely
# (safeCapture swallows the no-op). After first-boot setup at the SITE_URL,
# create a project, copy the Project API key into POSTHOG_KEY below.
# ----------------------------------------------------------------------------
POSTHOG_KEY=
POSTHOG_HOST=http://localhost:8000
# Public-side variants exposed to the browser bundle. Same values, NEXT_PUBLIC_*
# so Next.js exposes them client-side.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=http://localhost:8000
# Shared dashboard URL pasted into /chikaq for the embedded analytics frame.
# PostHog → Dashboard → Share → toggle "Share dashboard" → copy URL.
POSTHOG_DASHBOARD_URL=

# PostHog stack secrets (used only by docker-compose; safe defaults for dev).
POSTHOG_PG_USER=posthog
POSTHOG_PG_PASSWORD=posthog
POSTHOG_PG_DB=posthog
POSTHOG_SITE_URL=http://localhost:8000
POSTHOG_SECRET_KEY=replace-me-with-a-32-plus-character-random-string
POSTHOG_IS_BEHIND_PROXY=true
POSTHOG_DISABLE_SECURE_SSL_REDIRECT=true
