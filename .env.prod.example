# ─────────────────────────────────────────────────────────────────────────────
# Production environment template for gallery-hub.
#
# Copy to .env.prod (gitignored) and fill in real values. NEVER commit secrets.
# Required vars use ${VAR:?} in docker-compose.prod.yml — compose will refuse
# to start if any are blank.
#
# Secret generation cheatsheet (POSIX):
#   openssl rand -hex 24        # 48 hex chars — passwords, access keys
#   openssl rand -base64 32     # 32+ chars   — SESSION_PASSWORD, SECRET_KEY
#   openssl rand -hex 16        # 32 hex chars — WIDGET_TOKEN
# Windows PowerShell equivalent:
#   -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | % {[char]$_})
# ─────────────────────────────────────────────────────────────────────────────

# ── Build / image references ─────────────────────────────────────────────────
# Tag or sha of the image GitHub Actions pushes. Pin to an explicit sha or
# release tag in production — :latest is fine for rolling staging only.
GALLERY_APP_IMAGE=ghcr.io/vatsonio/gallery-hub:latest
GALLERY_WORKER_IMAGE=ghcr.io/vatsonio/gallery-hub-worker:latest
GALLERY_BACKUP_IMAGE=ghcr.io/vatsonio/gallery-hub-backup:latest

# Surfaced via /api/health and shown in admin footers. Use the git sha or
# release tag of the deployed build.
APP_VERSION=prod

# ── Gallery Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=gallery
# REQUIRED. `openssl rand -hex 24`
POSTGRES_PASSWORD=
POSTGRES_DB=gallery_hub
# REQUIRED. Internal Docker-network DSN — uses the service name.
# Must match the POSTGRES_* values above.
DATABASE_URL=postgresql://gallery:CHANGE_ME@gallery-postgres:5432/gallery_hub

# ── MinIO ────────────────────────────────────────────────────────────────────
# Root credentials — used only by MinIO itself, kept separate from the
# access-key/secret-key pair the app uses.
# REQUIRED. `openssl rand -hex 24`
MINIO_ROOT_USER=gallery-root
# REQUIRED. `openssl rand -hex 24`
MINIO_ROOT_PASSWORD=

# Programmatic credentials the gallery-app + gallery-worker use to read/write
# objects. After first boot, generate these in the MinIO console under
# "Access Keys" and paste here (alternatively, reuse root creds in low-trust
# single-tenant deploys).
# REQUIRED. `openssl rand -hex 16`
MINIO_ACCESS_KEY=
# REQUIRED. `openssl rand -hex 24`
MINIO_SECRET_KEY=

# Bucket the gallery writes into. Auto-created on first upload if missing.
MINIO_BUCKET=gallery
MINIO_REGION=us-east-1

# Internal endpoint — what the app + worker hit inside Docker.
MINIO_ENDPOINT=http://gallery-minio:9000
# REQUIRED. Public endpoint — what the browser sees in presigned URLs.
# Must be HTTPS and reachable through Cloudflare Tunnel.
MINIO_PUBLIC_ENDPOINT=https://minio.gallery.divass.space
# CORS origin MinIO allows for browser PUT/GET. Set to your PUBLIC_BASE_URL.
MINIO_API_CORS_ALLOW_ORIGIN=https://gallery.divass.space
# Redirect target MinIO uses for browser bounces.
MINIO_BROWSER_REDIRECT_URL=https://minio.gallery.divass.space

# ── Gallery app ──────────────────────────────────────────────────────────────
# REQUIRED. 32+ random chars for iron-session cookie encryption.
# `openssl rand -base64 32`
SESSION_PASSWORD=

# REQUIRED. Absolute URL the gallery is served from. No trailing slash.
PUBLIC_BASE_URL=https://gallery.divass.space

# Initial admin seed — used once by scripts/seed-admin.ts on first boot.
# Change this password IMMEDIATELY after first login via the admin UI.
ADMIN_EMAIL=admin@divass.space
ADMIN_PASSWORD=

# Bearer token for the personal-hub widget endpoint (/api/widget/summary).
# Leave blank to disable the endpoint (route returns 503).
# `openssl rand -hex 32`
WIDGET_TOKEN=

# ── imgproxy (on-demand resizing) ───────────────────────────────────────────
# Replaces the worker's WEBP/AVIF pre-encode pipeline. Originals stay in
# MinIO under albums/{albumId}/{photoId}/original.{ext}; imgproxy reads
# them lazily over the internal Docker network and serves resized output
# negotiated against the browser Accept header.
#
# Cloudflare Tunnel must expose the imgproxy service on a separate
# hostname so the browser can reach it directly. Recommended:
#   img.gallery.divass.space → http://gallery-imgproxy:8080

# REQUIRED. 32+ hex chars each — anyone holding both can forge URLs.
# `openssl rand -hex 32`
IMGPROXY_KEY=
IMGPROXY_SALT=

# REQUIRED. Public hostname the browser hits.
PUBLIC_IMGPROXY_URL=https://img.gallery.divass.space
# Internal URL imgproxy is reachable at from inside Docker (server-side use).
IMGPROXY_URL=http://gallery-imgproxy:8080
# Internal endpoint imgproxy reads originals from. Defaults to the in-cluster
# MinIO service hostname; override if you run imgproxy standalone.
IMGPROXY_S3_ENDPOINT=http://gallery-minio:9000

# Output knobs. Defaults match the historical WEBP variant quality.
IMGPROXY_QUALITY=82
IMGPROXY_AVIF_SPEED=8
# Progressive JPEG + interlaced PNG so the browser paints a low-res pass
# before the final bytes arrive. ~5% extra JPEG bytes; the perceived-perf
# win on slow networks is worth it.
IMGPROXY_JPEG_PROGRESSIVE=true
IMGPROXY_PNG_INTERLACED=true
# Parallel libvips encodes. Default 4 — raise to 10 if your imgproxy host
# has 2+ vCPU. Lower if you observe sustained 100% CPU on cold-cache fans.
IMGPROXY_CONCURRENCY=10
IMGPROXY_TTL=31536000
# Cap input resolution (megapixels) to defuse memory-amplification attacks.
IMGPROXY_MAX_SRC_RESOLUTION=50

# pg-boss worker concurrency — how many derivative jobs run in parallel.
# 2 is safe on a 2-vCPU VPS; raise for beefier hosts.
WORKER_CONCURRENCY=2

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Token mode (simplest): create the tunnel in the Cloudflare Zero Trust UI,
# add the three public hostnames there, copy the connector token here.
# Alternative: credentials-file mode — leave blank and mount
# deploy/cloudflared/{config.yml,credentials.json}, then override the
# cloudflared command in docker-compose.prod.yml.
CF_TUNNEL_TOKEN=

# ── PostHog (self-hosted) ────────────────────────────────────────────────────
# Dedicated Postgres for PostHog — separate from the gallery DB.
POSTHOG_PG_USER=posthog
# REQUIRED. `openssl rand -hex 24`
POSTHOG_PG_PASSWORD=
POSTHOG_PG_DB=posthog

# REQUIRED. 32+ random chars. `openssl rand -base64 32`
POSTHOG_SECRET_KEY=

# Where PostHog believes it is being served from. Used for absolute links
# in emails and OAuth callbacks.
POSTHOG_SITE_URL=https://posthog.gallery.divass.space

# TLS is terminated at Cloudflare — PostHog must NOT try to redirect to HTTPS
# (it would loop) and must trust X-Forwarded-* headers from the tunnel.
POSTHOG_IS_BEHIND_PROXY=true
POSTHOG_DISABLE_SECURE_SSL_REDIRECT=true
POSTHOG_TRUST_ALL_PROXIES=true

# After PostHog first-boot:
#   1. Visit https://posthog.gallery.divass.space → create the admin account
#   2. Project Settings → Project API Key → copy phc_... value
#   3. Paste into BOTH the server (POSTHOG_KEY) and client (NEXT_PUBLIC_*) vars
#   4. Restart gallery-app so the env reload propagates
POSTHOG_KEY=
POSTHOG_HOST=https://posthog.gallery.divass.space
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://posthog.gallery.divass.space

# After building a dashboard inside PostHog, share it and paste the URL here
# so /chikaq can embed it.
POSTHOG_DASHBOARD_URL=

# ── Backup + disaster recovery ───────────────────────────────────────────────
# See docs/backup.md for the full runbook (architecture, schedules, restore).

# REQUIRED for the gallery-backup container.
# Symmetric passphrase used by `gpg --symmetric --cipher-algo AES256`. Generate
# something long & random and store it in a password manager — losing it makes
# the dumps unreadable.
#   openssl rand -base64 48
BACKUP_GPG_PASSPHRASE=

# Cron schedules (5-field). Defaults: pg-dump 03:00 UTC, mirror 04:00 UTC.
BACKUP_SCHEDULE_PG=0 3 * * *
BACKUP_SCHEDULE_MIRROR=0 4 * * *

# Retention windows for pg-backup.sh (number of files kept per bucket).
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=6

# Cold-storage target for the MinIO mirror. Choose one and fill the matching
# block below. Default `local` writes into the gallery_mirror_prod volume —
# fine for evaluation, NOT a real disaster-recovery story.
#   b2     → Backblaze B2 via S3-compatible endpoint
#   r2     → Cloudflare R2
#   local  → local volume (gallery_mirror_prod)
BACKUP_TARGET=local

# Backblaze B2 — required when BACKUP_TARGET=b2
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
# e.g. https://s3.us-west-002.backblazeb2.com
B2_ENDPOINT=

# Cloudflare R2 — required when BACKUP_TARGET=r2
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=

# Storage quota in bytes. When MinIO usage crosses 85% of this value, the
# pg-boss `storage-usage-check` worker emits a `storage_critical` PostHog
# event. Leave blank to disable the alert (dashboard still shows usage).
# Example: 107374182400 = 100 GiB.
STORAGE_QUOTA_BYTES=

# Read-only mount path inside gallery-app where /chikaq looks for the backup
# manifests (last-backup.json, last-mirror.json). Must match the volume mount
# you wire up in docker-compose.prod.yml when surfacing manifests to the app.
# Leave blank to render "Last backup: never" — usage figures still work.
BACKUP_MANIFEST_DIR=

# ── Telegram notifications ───────────────────────────────────────────────────
# Real-time push alerts when clients engage with shared galleries. Full
# setup guide: docs/notifications.md (covers bot creation, chat_id lookup,
# multi-recipient strategy). Leave TELEGRAM_BOT_TOKEN blank to disable
# dispatch — the worker will mark rows 'skipped' and no API calls leave
# the host. Set both vars before tuning rules in /admin/notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_RATE_LIMIT_PER_MINUTE=20
